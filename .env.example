# Copy to .env.local and fill in values (never commit .env.local)

# Required for /api/digital-twin on Vercel (also set in Vercel → Settings → Environment Variables)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Live demo URLs (set after deploying flagship apps)
NEXT_PUBLIC_DEMO_RECRUITAI_URL=
NEXT_PUBLIC_DEMO_SUPPORTAI_URL=
NEXT_PUBLIC_DEMO_SALES_CRM_URL=

# GitHub Pages builds set this automatically to https://yatharthsharma1309.github.io
NEXT_PUBLIC_SITE_URL=

# Contact form (Resend) — Vercel production
RESEND_API_KEY=re_xxxxxxxxx
CONTACT_TO_EMAIL=yatharthsharma1309@gmail.com
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>

# Contact form (Web3Forms) — GitHub Pages static deploy only (GitHub Actions secret: WEB3FORMS_ACCESS_KEY)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
