# Copy to .env.local and fill in values (never commit .env.local)

# Required for /api/digital-twin (also set OPENROUTER_API_KEY in Vercel → Settings → Environment Variables)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Public site URL (GitHub Pages)
NEXT_PUBLIC_SITE_URL=https://yatharthsharma1309.github.io

# GitHub Pages static build — contact form uses Web3Forms (no server / Resend on Pages)
# Get a free access key at https://web3forms.com (emails you + stores submissions)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# Local dev only — Resend contact API (/api/contact) and Digital Twin (/api/digital-twin)
# RESEND_API_KEY=re_xxxxxxxxx
# CONTACT_TO_EMAIL=yatharthsharma1309@gmail.com
# CONTACT_FROM_EMAIL=onboarding@resend.dev
# OPENROUTER_API_KEY=your-openrouter-api-key-here
