# Copy to .env.local and fill in values (never commit .env.local)

# Required for /api/digital-twin (also set OPENROUTER_API_KEY in Vercel → Settings → Environment Variables)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Public site URL for OpenRouter HTTP-Referer (auto-detected on Vercel via VERCEL_URL if unset)
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional — paste full LinkedIn About/experience TEXT here (not a profile URL)
# LINKEDIN_PROFILE_FULL_TEXT=
